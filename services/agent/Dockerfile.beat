# Celery Beat (scheduler) image — singleton, never scale past 1 replica.
# Build context: ./services/agent

FROM python:3.12-slim AS builder
WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libxml2-dev libxslt-dev \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
RUN pip install --user --no-cache-dir .

FROM python:3.12-slim

ARG VERSION=dev
LABEL org.opencontainers.image.source="https://github.com/MountainManTechnology/Serendip.bot"
LABEL org.opencontainers.image.version="${VERSION}"

RUN useradd --create-home --uid 1000 beat
USER beat
WORKDIR /app

COPY --from=builder /root/.local /home/beat/.local
COPY --chown=beat:beat . .

ENV PATH=/home/beat/.local/bin:$PATH \
    PYTHONUNBUFFERED=1

CMD ["celery", "-A", "agent.celery_app", "beat", \
     "--loglevel=info", \
     "--schedule=/tmp/celerybeat-schedule"]
